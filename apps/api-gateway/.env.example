# Server
PORT="3000"
API_PREFIX="api"

# PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/llm_gateway?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_CLUSTER_MODE="false"

# LiteLLM Proxy
LITELLM_API_BASE="http://localhost:4000"
LITELLM_MASTER_KEY="sk-litellm-master-key"

UPSTREAM_TIMEOUT="120000"
