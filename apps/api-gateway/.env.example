# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/llm_gateway?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# LiteLLM Proxy
LITELLM_URL=http://localhost:4000
LITELLM_API_KEY=

# JWT
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRATION=7d

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# OpenTelemetry
OTEL_SERVICE_NAME=llm-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=30000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=60000
