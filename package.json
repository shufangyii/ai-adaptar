{
  "name": "llm-gateway-platform",
  "version": "0.0.1",
  "private": true,
  "description": "Enterprise-grade LLM Gateway with NestJS and LiteLLM",
  "keywords": [
    "llm",
    "gateway",
    "nestJS",
    "litellm",
    "enterprise"
  ],
  "author": "Your Team",
  "license": "UNLICENSED",
  "scripts": {
    "prepare": "husky install",
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md}\"",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/eslint-plugin": "^8.24.1",
    "@typescript-eslint/parser": "^8.24.1",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.1",
    "eslint-plugin-prettier": "^5.2.3",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.2.5",
    "turbo": "^2.4.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
