{
  "name": "ai-adaptar",
  "version": "1.0.0",
  "description": "Multi-vendor AI Model Adapter Layer with Microservices Architecture",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "dc:up": "docker-compose up -d",
    "dc:down": "docker-compose down"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.2",
    "@types/node": "^20.11.20",
    "prettier": "^3.2.5",
    "turbo": "^1.12.4",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
