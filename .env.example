# ===================================
# AI Adaptar 环境配置
# ===================================

# NATS 配置
NATS_URL=nats://localhost:4222
# NATS_USER=
# NATS_PASS=

# Redis 配置
REDIS_URL=redis://localhost:6379

# 数据库配置
DATABASE_URL=postgresql://aiadaptar:aiadaptar123@localhost:5432/aiadaptar

# ===================================
# AI 提供商 API Keys
# ===================================

# OpenAI
OPENAI_API_KEY=sk-xxxxxxxxxxxxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx

# Azure OpenAI
AZURE_API_KEY=xxxxxxxxxxxxx
AZURE_ENDPOINT=https://your-resource.openai.azure.com/

# Google Gemini
GEMINI_API_KEY=xxxxxxxxxxxxx

# 阿里通义千问
QWEN_API_KEY=sk-xxxxxxxxxxxxx

# ===================================
# 服务端口配置
# ===================================

API_GATEWAY_PORT=3000
AI_CORE_PORT=3001

# ===================================
# CORS 配置
# ===================================

CORS_ORIGIN=*

# ===================================
# 日志配置
# ===================================

LOG_LEVEL=info
LOG_FORMAT=json

# ===================================
# 安全配置
# ===================================

# JWT 密钥 (TODO: 实现 JWT 认证)
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# ===================================
# 速率限制配置
# ===================================

RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ===================================
# 计费配置 (TODO: 实现)
# ===================================

DEFAULT_QUOTA=1000000
QUOTA_RESET_PERIOD=monthly
